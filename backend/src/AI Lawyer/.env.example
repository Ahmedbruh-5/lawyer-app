# =============================================================================
# AI Lawyer - environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env` (same directory) and fill in real values.
# python-dotenv loads .env automatically when rag_chatbot.py starts.
# =============================================================================

# ---- Google Gemini (default backend, free tier) -----------------------------
# Get a free key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=paste-your-key-here

# ---- RAG HTTP API (api_server.py + MERN Express) -----------------------------
# Generate once:  py -c "import secrets; print(secrets.token_urlsafe(48))"
# Put the SAME value in your MERN backend .env as RAG_API_KEY (for X-API-Key).
RAG_API_KEY=paste-a-long-random-string-here

# ---- CORS (only if the *browser* calls FastAPI directly — e.g. Vite dev) -----
# Comma-separated origins. Defaults include localhost:5173 and :3000.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# LAN Vite URLs matching http://192.168.*:* are allowed by default via regex.
# CORS_DISABLE_LAN_REGEX=1

# ---- Optional overrides (all have sensible defaults) ------------------------
# Pick any free-tier Gemini model:
#   gemini-2.5-flash        (10 RPM,  ~500 RPD)  <- default primary
#   gemini-2.5-flash-lite   (15 RPM, 1000 RPD)  <- default fallback on rate limit
#   gemini-2.5-pro          ( 5 RPM,   100 RPD, best quality)
# LLM_BACKEND=gemini
# LLM_MODEL=gemini-2.5-flash
# LLM_MODEL_FALLBACK=gemini-2.5-flash-lite
# LLM_TEMPERATURE=0.1

# RAG corpus JSONL (default: pak_laws_rag_merged.jsonl). Build merge with:
#   py merge_rag_corpora.py
# RAG_CORPUS_JSONL=pak_laws_rag.jsonl

# Embedding model override (see rag_config.py for choices)
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# EMBEDDING_DEVICE=cpu        # or cuda / mps
# EMBEDDING_BATCH_SIZE=32

# Retrieval tuning
# TOP_K=5
# FETCH_K=20
# USE_MMR=true
# MMR_LAMBDA=0.5

# ---- Other LLM backends (enable ONE by installing its package) --------------
# OPENAI_API_KEY=sk-...                   # pip install langchain-openai
# ANTHROPIC_API_KEY=sk-ant-...            # pip install langchain-anthropic
